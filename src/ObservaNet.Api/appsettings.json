{
  "ConnectionStrings": {
    "Default": "Data Source=observanet.db"
  },
  "Elasticsearch": {
    "Uri": ""
  },
  "AllowedOrigins": [ "http://localhost:5173", "http://localhost:4200" ],
  "Serilog": {
